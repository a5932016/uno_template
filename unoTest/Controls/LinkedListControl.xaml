<UserControl x:Class="unoTest.Controls.LinkedListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:unoTest.Controls">

    <!-- ====================================================================
         List 內 Button 連線控件
         在 ListView 項目之間繪製連接線
         ==================================================================== -->

    <Grid x:Name="RootGrid">
        <!-- 連線層 (在列表下方) -->
        <Canvas x:Name="LinkCanvas" 
                IsHitTestVisible="False"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"/>
        
        <!-- 列表層 -->
        <ListView x:Name="ItemsListView"
                  Background="Transparent"
                  SelectionMode="Single"
                  SelectionChanged="ItemsListView_SelectionChanged">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="8,4" MinHeight="48">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- 連接點 (左側) -->
                        <Ellipse x:Name="LeftConnector"
                                 Grid.Column="0"
                                 Width="12" Height="12"
                                 Fill="{ThemeResource SystemAccentColor}"
                                 Stroke="{ThemeResource SystemAccentColorLight1}"
                                 StrokeThickness="2"
                                 Margin="0,0,8,0"
                                 VerticalAlignment="Center"
                                 PointerPressed="Connector_PointerPressed"
                                 Tag="Left"/>

                        <!-- 內容區 -->
                        <Border Grid.Column="1"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="8"
                                Padding="12,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <FontIcon Grid.Column="0" 
                                          Glyph="{Binding Icon}"
                                          Margin="0,0,12,0"
                                          VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}"
                                               Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                    <TextBlock Text="{Binding Description}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Opacity="0.7"
                                               Visibility="{Binding Description, Converter={StaticResource StringEmptyToVisibilityConverter}}"/>
                                </StackPanel>

                                <Button Grid.Column="2"
                                        Content="&#xE712;"
                                        FontFamily="{StaticResource SymbolThemeFontFamily}"
                                        Background="Transparent"
                                        Padding="8"
                                        VerticalAlignment="Center">
                                    <Button.Flyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem Text="連接到..." Click="LinkTo_Click"/>
                                            <MenuFlyoutItem Text="取消連接" Click="Unlink_Click"/>
                                            <MenuFlyoutSeparator/>
                                            <MenuFlyoutItem Text="編輯" Click="Edit_Click"/>
                                            <MenuFlyoutItem Text="刪除" Click="Delete_Click"/>
                                        </MenuFlyout>
                                    </Button.Flyout>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- 連接點 (右側) -->
                        <Ellipse x:Name="RightConnector"
                                 Grid.Column="2"
                                 Width="12" Height="12"
                                 Fill="{ThemeResource SystemAccentColor}"
                                 Stroke="{ThemeResource SystemAccentColorLight1}"
                                 StrokeThickness="2"
                                 Margin="8,0,0,0"
                                 VerticalAlignment="Center"
                                 PointerPressed="Connector_PointerPressed"
                                 Tag="Right"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
