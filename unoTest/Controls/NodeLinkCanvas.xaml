<UserControl x:Class="unoTest.Controls.NodeLinkCanvas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="800">

    <!-- ====================================================================
         節點連線畫布控件
         
         功能說明：
         1. 可放置多個按鈕節點
         2. 節點之間可用線條連接
         3. 支援拖曳移動節點
         4. 支援新增/刪除連線
         5. 可自訂節點樣式和連線樣式
         ==================================================================== -->

    <Grid>
        <!-- 背景格線（可選） -->
        <Canvas x:Name="GridCanvas" 
                Background="Transparent"
                Visibility="{Binding ShowGrid, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- 連線層（在節點下方） -->
        <Canvas x:Name="LinkCanvas" Background="Transparent"/>

        <!-- 節點層 -->
        <Canvas x:Name="NodeCanvas" Background="Transparent"/>

        <!-- 工具列 -->
        <StackPanel x:Name="ToolBar"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="8"
                    Spacing="4"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="4"
                    Padding="8">
            
            <Button x:Name="AddNodeButton"
                    ToolTipService.ToolTip="新增節點"
                    Click="AddNodeButton_Click">
                <FontIcon Glyph="&#xE710;" FontSize="16"/>
            </Button>
            
            <Button x:Name="AddLinkButton"
                    ToolTipService.ToolTip="新增連線（先選擇起點節點）"
                    Click="AddLinkButton_Click">
                <FontIcon Glyph="&#xE71B;" FontSize="16"/>
            </Button>
            
            <Button x:Name="DeleteButton"
                    ToolTipService.ToolTip="刪除選中項目"
                    Click="DeleteButton_Click">
                <FontIcon Glyph="&#xE74D;" FontSize="16"/>
            </Button>
            
            <Border Width="1" Height="24" Background="{ThemeResource SystemControlForegroundBaseMediumLowBrush}"/>
            
            <Button x:Name="ClearAllButton"
                    ToolTipService.ToolTip="清除全部"
                    Click="ClearAllButton_Click">
                <FontIcon Glyph="&#xE894;" FontSize="16"/>
            </Button>
            
            <Button x:Name="AutoLayoutButton"
                    ToolTipService.ToolTip="自動排列"
                    Click="AutoLayoutButton_Click">
                <FontIcon Glyph="&#xE8C8;" FontSize="16"/>
            </Button>
        </StackPanel>

        <!-- 狀態列 -->
        <Border x:Name="StatusBar"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Margin="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="4"
                Padding="12,6">
            <TextBlock x:Name="StatusText" 
                       Text="拖曳節點移動位置，點擊「新增連線」後依序選擇起點和終點"
                       Opacity="0.7"
                       FontSize="12"/>
        </Border>
    </Grid>
</UserControl>
