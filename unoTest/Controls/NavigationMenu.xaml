<UserControl x:Class="unoTest.Controls.NavigationMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:utu="using:Uno.Toolkit.UI"
             mc:Ignorable="d">

    <!-- ====================================================================
         側邊導航選單控件
         
         功能說明：
         1. 可折疊/展開
         2. 多層級選單
         3. 圖標支援
         4. 選中狀態高亮
         ==================================================================== -->

    <Grid>
        <Grid.RowDefinitions>
            <!-- Logo/Header 區域 -->
            <RowDefinition Height="Auto"/>
            <!-- 選單項目 -->
            <RowDefinition Height="*"/>
            <!-- 底部按鈕 -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}"
                Padding="16,12"
                BorderThickness="0,0,0,1"
                BorderBrush="{ThemeResource SystemControlForegroundBaseMediumLowBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <Image Source="ms-appx:///Assets/Icons/icon_foreground.svg"
                       Width="32" Height="32"
                       Grid.Column="0"/>

                <!-- 應用名稱 -->
                <TextBlock x:Name="AppTitle"
                           Grid.Column="1"
                           Text="Uno Template"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           Visibility="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <!-- 折疊按鈕 -->
                <Button x:Name="CollapseButton"
                        Grid.Column="2"
                        Style="{StaticResource MaterialIconButtonStyle}"
                        Click="CollapseButton_Click">
                    <FontIcon x:Name="CollapseIcon" Glyph="&#xE76B;" FontSize="12"/>
                </Button>
            </Grid>
        </Border>

        <!-- 選單項目 -->
        <ListView x:Name="MenuListView"
                  Grid.Row="1"
                  ItemsSource="{Binding MenuItems, RelativeSource={RelativeSource TemplatedParent}}"
                  SelectionMode="Single"
                  SelectionChanged="MenuListView_SelectionChanged">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="12,10" ToolTipService.ToolTip="{Binding Title}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- 圖標 -->
                        <FontIcon Grid.Column="0" 
                                  Glyph="{Binding Icon}" 
                                  FontSize="16"
                                  Margin="4,0,0,0"/>

                        <!-- 標題 -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Title}"
                                   Margin="16,0,0,0"
                                   VerticalAlignment="Center"/>

                        <!-- 子選單指示器 -->
                        <FontIcon Grid.Column="2"
                                  Glyph="&#xE76C;"
                                  FontSize="10"
                                  Visibility="{Binding HasChildren, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="MinHeight" Value="40"/>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <!-- 底部按鈕 -->
        <StackPanel Grid.Row="2"
                    Padding="8"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseMediumLowBrush}">
            
            <!-- 設定 -->
            <Button HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Padding="12,10"
                    Style="{StaticResource MaterialTextButtonStyle}"
                    Command="{Binding SettingsCommand, RelativeSource={RelativeSource TemplatedParent}}">
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <FontIcon Glyph="&#xE713;" FontSize="16"/>
                    <TextBlock Text="設定"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
