<UserControl x:Class="unoTest.Controls.LoadingOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <!-- ====================================================================
         載入中遮罩控件
         用於顯示載入狀態與進度
         ==================================================================== -->

    <Grid x:Name="OverlayGrid"
          Background="#80000000"
          Visibility="{Binding IsLoading, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVisibilityConverter}}">

        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="12"
                Padding="32"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MinWidth="200">
            <StackPanel Spacing="16" HorizontalAlignment="Center">
                <!-- 載入動畫 -->
                <ProgressRing x:Name="LoadingRing"
                              IsActive="{Binding IsLoading, RelativeSource={RelativeSource TemplatedParent}}"
                              Width="48"
                              Height="48"/>

                <!-- 載入文字 -->
                <TextBlock x:Name="LoadingText"
                           Text="{Binding Message, RelativeSource={RelativeSource TemplatedParent}, FallbackValue='載入中...'}"
                           HorizontalAlignment="Center"
                           Style="{StaticResource BodyTextBlockStyle}"/>

                <!-- 進度條（選用） -->
                <ProgressBar x:Name="ProgressBar"
                             Value="{Binding Progress, RelativeSource={RelativeSource TemplatedParent}}"
                             Maximum="100"
                             Visibility="{Binding ShowProgress, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVisibilityConverter}}"
                             MinWidth="150"/>

                <!-- 取消按鈕（選用） -->
                <Button x:Name="CancelButton"
                        Content="取消"
                        Command="{Binding CancelCommand, RelativeSource={RelativeSource TemplatedParent}}"
                        Visibility="{Binding CanCancel, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVisibilityConverter}}"
                        Style="{StaticResource MaterialTextButtonStyle}"
                        HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
