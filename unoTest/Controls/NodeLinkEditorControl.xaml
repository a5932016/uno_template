<UserControl x:Class="unoTest.Controls.NodeLinkEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:unoTest.Controls"
             x:Name="RootControl"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="900">

    <!-- ====================================================================
         節點流程編輯器控件（包裝 NodeLinkCanvas + 屬性面板）

         功能說明：
         1. 左側為 NodeLinkCanvas 畫布（含工具列與格線）
         2. 右側為屬性面板：顯示選取節點的 ID、標題（可編輯）、座標
         3. 右側底部列出所有節點，點擊可快速選取
         4. 透過 ViewModel 屬性（NodeLinkCanvasViewModel）驅動畫布與面板
         ==================================================================== -->

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- 畫布區 -->
            <ColumnDefinition Width="*"/>
            <!-- 屬性面板 -->
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>

        <!-- 左側：NodeLinkCanvas 畫布 -->
        <controls:NodeLinkCanvas Grid.Column="0"
                                  ShowGrid="True"
                                  NodeMinWidth="120"
                                  ViewModel="{x:Bind ViewModel, Mode=OneWay}"/>

        <!-- 左右分隔線 -->
        <Border Grid.Column="0"
                Width="1"
                HorizontalAlignment="Right"
                Background="{ThemeResource CardStrokeColorDefaultBrush}"/>

        <!-- 右側：屬性面板 -->
        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="12" Spacing="10">

                <!-- 面板標題 -->
                <TextBlock Text="屬性面板"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           Margin="0,0,0,2"/>

                <!-- 統計卡片 -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="6"
                        Padding="12,10">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock x:Name="NodeCountText"
                                       Text="0"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="節點"
                                       FontSize="11"
                                       Opacity="0.6"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock x:Name="LinkCountText"
                                       Text="0"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="連線"
                                       FontSize="11"
                                       Opacity="0.6"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 無選取提示 -->
                <Border x:Name="NoSelectionPanel"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="6"
                        Padding="12,10">
                    <TextBlock Text="請點擊畫布中的節點以查看屬性"
                               Opacity="0.5"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- 節點屬性（有選取時顯示） -->
                <StackPanel x:Name="NodePropertiesPanel"
                            Spacing="8"
                            Visibility="Collapsed">

                    <!-- ID -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="6"
                            Padding="12,10">
                        <StackPanel Spacing="4">
                            <TextBlock Text="節點 ID"
                                       FontSize="11"
                                       Opacity="0.5"/>
                            <TextBlock x:Name="NodeIdText"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <!-- 標題（可編輯） -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="6"
                            Padding="12,10">
                        <StackPanel Spacing="4">
                            <TextBlock Text="標題"
                                       FontSize="11"
                                       Opacity="0.5"/>
                            <TextBox x:Name="NodeTitleBox"
                                     PlaceholderText="輸入節點名稱"
                                     LostFocus="NodeTitleBox_LostFocus"/>
                        </StackPanel>
                    </Border>

                    <!-- 座標（唯讀） -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="6"
                            Padding="12,10">
                        <StackPanel Spacing="4">
                            <TextBlock Text="座標"
                                       FontSize="11"
                                       Opacity="0.5"/>
                            <TextBlock x:Name="NodePositionText"
                                       FontSize="12"/>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- 節點列表 -->
                <TextBlock Text="所有節點"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           Margin="0,4,0,0"/>

                <StackPanel x:Name="NodeListPanel" Spacing="4"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
