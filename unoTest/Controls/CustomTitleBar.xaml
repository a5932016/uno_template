<UserControl x:Class="unoTest.Controls.CustomTitleBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:unoTest.Controls"
             xmlns:converters="using:unoTest.Converters"
             xmlns:vm="using:unoTest.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="48"
             d:DesignWidth="900">

  <!--
    CustomTitleBar — 客製化標題列
    DataContext = TitleBarViewModel（由 Shell.xaml 綁定）

    三欄佈局：
    ┌─────────────────────────────────────────────────────────────┐
    │ [Logo][AppName] │ [Tab:首頁][Tab:產品][Tab:設定] / [標題]  │ [🔔][🌙][⚙][User][▬□✕] │
    └─────────────────────────────────────────────────────────────┘

    VisualStateManager：
    - TabsMode：中間欄顯示 Tab 導航（主頁面）
    - DetailMode：中間欄顯示頁面標題 + 左欄顯示返回按鈕（詳情頁面）
  -->

  <UserControl.Resources>
    <!-- ThemeIconConverter 本地資源 -->
    <converters:ThemeIconConverter x:Key="ThemeIconConverter"/>
    <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

    <!-- Tab 按鈕樣式（RadioButton 外觀像 Tab） -->
    <Style x:Key="TitleBarTabStyle" TargetType="RadioButton">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{ThemeResource SystemControlForegroundBaseHighBrush}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="16,0"/>
      <Setter Property="Height" Value="48"/>
      <Setter Property="MinWidth" Value="80"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="RadioButton">
            <Grid x:Name="Root" Background="{TemplateBinding Background}">
              <VisualStateManager.VisualStateGroups>
                <VisualStateGroup x:Name="CommonStates">
                  <VisualState x:Name="Normal"/>
                  <VisualState x:Name="PointerOver">
                    <Storyboard>
                      <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Background">
                        <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorSecondaryBrush}"/>
                      </ObjectAnimationUsingKeyFrames>
                    </Storyboard>
                  </VisualState>
                  <VisualState x:Name="Pressed">
                    <Storyboard>
                      <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Background">
                        <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorTertiaryBrush}"/>
                      </ObjectAnimationUsingKeyFrames>
                    </Storyboard>
                  </VisualState>
                </VisualStateGroup>
                <VisualStateGroup x:Name="CheckStates">
                  <VisualState x:Name="Unchecked"/>
                  <VisualState x:Name="Checked">
                    <!-- 選中時：底部顯示強調色橫線 -->
                    <Storyboard>
                      <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ActiveIndicator" Storyboard.TargetProperty="Visibility">
                        <DiscreteObjectKeyFrame KeyTime="0" Value="Visible"/>
                      </ObjectAnimationUsingKeyFrames>
                      <ObjectAnimationUsingKeyFrames Storyboard.TargetName="TabText" Storyboard.TargetProperty="FontWeight">
                        <DiscreteObjectKeyFrame KeyTime="0" Value="SemiBold"/>
                      </ObjectAnimationUsingKeyFrames>
                    </Storyboard>
                  </VisualState>
                </VisualStateGroup>
              </VisualStateManager.VisualStateGroups>

              <!-- Tab 內容：圖示 + 文字 -->
              <StackPanel Orientation="Horizontal" Spacing="6"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Margin="{TemplateBinding Padding}">
                <FontIcon x:Name="TabIcon"
                          Glyph="{TemplateBinding Tag}"
                          FontSize="14"
                          Foreground="{TemplateBinding Foreground}"/>
                <TextBlock x:Name="TabText"
                           Text="{TemplateBinding Content}"
                           VerticalAlignment="Center"/>
              </StackPanel>

              <!-- 選中底線 -->
              <Border x:Name="ActiveIndicator"
                      Height="2"
                      VerticalAlignment="Bottom"
                      Background="{ThemeResource SystemAccentColor}"
                      Visibility="Collapsed"/>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </UserControl.Resources>

  <Grid x:Name="TitleBarRoot"
        Height="48"
        Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">

    <!-- VisualStateManager：根據 TitleBarMode 切換 UI -->
    <VisualStateManager.VisualStateGroups>
      <VisualStateGroup x:Name="TitleBarModeStates">

        <!-- TabsMode（預設）：顯示 Tab 導航，隱藏返回按鈕 -->
        <VisualState x:Name="TabsMode">
          <VisualState.Setters>
            <Setter Target="TabsSection.Visibility"  Value="Visible"/>
            <Setter Target="DetailSection.Visibility" Value="Collapsed"/>
            <Setter Target="BackButton.Visibility"    Value="Collapsed"/>
          </VisualState.Setters>
        </VisualState>

        <!-- DetailMode：隱藏 Tab，顯示頁面標題 + 返回按鈕 -->
        <VisualState x:Name="DetailMode">
          <VisualState.Setters>
            <Setter Target="TabsSection.Visibility"  Value="Collapsed"/>
            <Setter Target="DetailSection.Visibility" Value="Visible"/>
            <Setter Target="BackButton.Visibility"    Value="Visible"/>
          </VisualState.Setters>
        </VisualState>

      </VisualStateGroup>
    </VisualStateManager.VisualStateGroups>

    <Grid.ColumnDefinitions>
      <!-- 左側：Logo + AppName + 返回按鈕 -->
      <ColumnDefinition Width="Auto"/>
      <!-- 中間可拖曳區（主要顯示 Tabs 或頁面標題） -->
      <ColumnDefinition Width="*"/>
      <!-- 右側：功能按鈕 + 使用者 + 視窗控制 -->
      <ColumnDefinition Width="Auto"/>
    </Grid.ColumnDefinitions>

    <!--
      專用拖曳區（避免整個 TitleBar 都被視為 Non-Client 區導致 Tab/Button 不能點）
      實作策略：僅把最上方 8px 登記為 OS TitleBar 拖曳區，其餘區域維持正常互動。
    -->
    <Border x:Name="TitleBarDragRegion"
            Grid.ColumnSpan="3"
            Height="8"
            VerticalAlignment="Top"
            Background="Transparent"/>

    <!-- ================================================================
         左側欄：Logo + App 名稱 + 返回按鈕（Detail 模式顯示）
         ================================================================ -->
    <StackPanel Grid.Column="0"
                Orientation="Horizontal"
                Spacing="6"
                VerticalAlignment="Center"
                Margin="12,0,8,0">

      <!-- App Logo 圖片 -->
      <Image Source="ms-appx:///Assets/Icons/icon_foreground.svg"
             Width="24"
             Height="24"
             VerticalAlignment="Center"/>

      <!-- App 名稱文字 -->
      <TextBlock Text="unoTest"
                 FontSize="13"
                 FontWeight="SemiBold"
                 VerticalAlignment="Center"
                 Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"/>

      <!-- 分隔線 -->
      <Border Width="1"
              Height="20"
              Background="{ThemeResource SystemControlForegroundBaseMediumLowBrush}"
              Margin="6,0"/>

      <!-- 返回按鈕（Detail 模式時顯示，預設 Collapsed） -->
      <Button x:Name="BackButton"
              Style="{StaticResource MaterialIconButtonStyle}"
              Command="{Binding BackCommand}"
              Visibility="Collapsed"
              ToolTipService.ToolTip="返回">
        <FontIcon Glyph="&#xE72B;" FontSize="14"/>
      </Button>
    </StackPanel>

    <!-- ================================================================
         中間欄：Tab 導航 / 頁面標題（依 Mode 切換）
         ================================================================ -->
    <Grid Grid.Column="1" x:Name="DraggableArea" Background="Transparent">

      <!-- TabsMode：三個主要 Tab -->
      <StackPanel x:Name="TabsSection"
                  Orientation="Horizontal"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Stretch">

        <!-- Tab 0：首頁 -->
        <RadioButton x:Name="TabHome"
                     Style="{StaticResource TitleBarTabStyle}"
                     Content="首頁"
                     Tag="&#xE80F;"
                     GroupName="MainNavTabs"
                     IsChecked="True"
                     Checked="NavTab_Checked"/>

        <!-- Tab 1：產品 -->
        <RadioButton x:Name="TabProducts"
                     Style="{StaticResource TitleBarTabStyle}"
                     Content="產品"
                     Tag="&#xE8A5;"
                     GroupName="MainNavTabs"
                     Checked="NavTab_Checked"/>

        <!-- Tab 2：設定 -->
        <RadioButton x:Name="TabSettings"
                     Style="{StaticResource TitleBarTabStyle}"
                     Content="設定"
                     Tag="&#xE713;"
                     GroupName="MainNavTabs"
                     Checked="NavTab_Checked"/>
      </StackPanel>

      <!-- DetailMode：頁面標題文字 -->
      <TextBlock x:Name="DetailSection"
                 Text="{Binding DetailTitle}"
                 FontSize="14"
                 FontWeight="SemiBold"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
                 Visibility="Collapsed"/>
    </Grid>

    <!-- ================================================================
         右側欄：功能按鈕 + 使用者資訊 + 視窗控制
         ================================================================ -->
    <StackPanel Grid.Column="2"
                Orientation="Horizontal"
                Spacing="2"
                VerticalAlignment="Center"
                Margin="0,0,4,0">

      <!-- 通知按鈕 -->
      <Button x:Name="NotificationButton"
              Style="{StaticResource MaterialIconButtonStyle}"
              Command="{Binding NotificationCommand}"
              ToolTipService.ToolTip="通知">
        <Grid>
          <FontIcon Glyph="&#xE7E7;" FontSize="16"/>
          <Ellipse Width="8" Height="8"
                   Fill="Red"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Top"
                   Margin="0,-2,-2,0"
                   Visibility="{Binding HasNotifications, Converter={StaticResource BoolToVisibilityConverter}}"/>
        </Grid>
      </Button>

      <!-- 主題切換 -->
      <Button x:Name="ThemeToggleButton"
              Style="{StaticResource MaterialIconButtonStyle}"
              Command="{Binding ToggleThemeCommand}"
              ToolTipService.ToolTip="切換主題">
        <FontIcon Glyph="{Binding IsDarkTheme, Converter={StaticResource ThemeIconConverter}}"
                  FontSize="16"/>
      </Button>

      <!-- 設定按鈕 -->
      <Button x:Name="SettingsButton"
              Style="{StaticResource MaterialIconButtonStyle}"
              Command="{Binding SettingsCommand}"
              ToolTipService.ToolTip="設定">
        <FontIcon Glyph="&#xE713;" FontSize="16"/>
      </Button>

      <!-- 分隔線 -->
      <Border Width="1"
              Height="24"
              Background="{ThemeResource SystemControlForegroundBaseMediumLowBrush}"
              Margin="4,0"/>

      <!-- 使用者資訊（頭像 + 名稱） -->
      <Button x:Name="UserButton"
              Style="{StaticResource MaterialIconButtonStyle}"
              Padding="6,4"
              ToolTipService.ToolTip="{Binding UserName}">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <PersonPicture DisplayName="{Binding UserName}"
                         ProfilePicture="{Binding UserAvatar}"
                         Width="28"
                         Height="28"/>
          <TextBlock Text="{Binding UserName}"
                     VerticalAlignment="Center"
                     FontSize="12"/>
        </StackPanel>
        <Button.Flyout>
          <MenuFlyout>
            <MenuFlyoutItem Text="個人資料" Icon="Contact"/>
            <MenuFlyoutSeparator/>
            <MenuFlyoutItem Text="登出" Icon="BlockContact"/>
          </MenuFlyout>
        </Button.Flyout>
      </Button>

      <!-- ─── 視窗控制按鈕（僅 Desktop 平台） ─── -->
      <StackPanel x:Name="WindowControlButtons"
                  Orientation="Horizontal"
                  Spacing="0"
                  Margin="6,0,0,0">
        <Button x:Name="MinimizeButton"
                Style="{StaticResource WindowCaptionButtonStyle}"
                Click="MinimizeButton_Click"
                ToolTipService.ToolTip="最小化">
          <FontIcon Glyph="&#xE921;" FontSize="10"/>
        </Button>
        <Button x:Name="MaximizeButton"
                Style="{StaticResource WindowCaptionButtonStyle}"
                Click="MaximizeButton_Click"
                ToolTipService.ToolTip="最大化">
          <FontIcon x:Name="MaximizeIcon" Glyph="&#xE922;" FontSize="10"/>
        </Button>
        <Button x:Name="CloseButton"
                Style="{StaticResource WindowCaptionCloseButtonStyle}"
                Click="CloseButton_Click"
                ToolTipService.ToolTip="關閉">
          <FontIcon Glyph="&#xE8BB;" FontSize="10"/>
        </Button>
      </StackPanel>

      <!-- ★ 作業系統原生視窗按鈕（最小化/最大化/關閉）的空間預留
           ExtendsContentIntoTitleBar = true 時，OS 會在視窗右上角疊層繪製原生按鈕。
           此 Spacer 的寬度由 code-behind 根據 AppWindow.TitleBar.RightInset 設定，
           確保我們的功能按鈕（通知、主題等）不被系統按鈕遮擋。 -->
      <Border x:Name="SystemButtonSpacer" Width="0" VerticalAlignment="Stretch"/>

    </StackPanel>
  </Grid>
</UserControl>
