<UserControl x:Class="unoTest.Controls.CustomTitleBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:unoTest.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="48"
             d:DesignWidth="800">
    
    <!-- ====================================================================
         Uno Platform 客製化 TitleBar 控件
         功能：
         1. 應用程式圖標顯示
         2. 標題文字（可自訂）
         3. 導航按鈕（返回、首頁）
         4. 使用者資訊區域
         5. 主題切換按鈕
         6. 最小化/最大化/關閉按鈕（Desktop only）
         7. 支援拖曳移動視窗
         ==================================================================== -->
    
    <Grid x:Name="TitleBarRoot" 
          Height="48" 
          Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
        <Grid.ColumnDefinitions>
            <!-- 左側：圖標與導航 -->
            <ColumnDefinition Width="Auto"/>
            <!-- 中間：標題（可拖曳區域） -->
            <ColumnDefinition Width="*"/>
            <!-- 右側：使用者與視窗控制 -->
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- 左側區域：應用圖標與導航按鈕 -->
        <StackPanel Grid.Column="0" 
                    Orientation="Horizontal" 
                    Spacing="4"
                    VerticalAlignment="Center"
                    Margin="8,0,0,0">
            
            <!-- 應用程式圖標 -->
            <Image x:Name="AppIcon"
                   Source="ms-appx:///Assets/Icons/icon_foreground.svg"
                   Width="24" 
                   Height="24"
                   Margin="4,0"/>
            
            <!-- 返回按鈕 -->
            <Button x:Name="BackButton"
                    Style="{StaticResource MaterialIconButtonStyle}"
                    Command="{Binding BackCommand}"
                    Visibility="{Binding CanGoBack, Converter={StaticResource BoolToVisibilityConverter}}"
                    ToolTipService.ToolTip="返回">
                <FontIcon Glyph="&#xE72B;" FontSize="16"/>
            </Button>
            
            <!-- 首頁按鈕 -->
            <Button x:Name="HomeButton"
                    Style="{StaticResource MaterialIconButtonStyle}"
                    Command="{Binding HomeCommand}"
                    ToolTipService.ToolTip="首頁">
                <FontIcon Glyph="&#xE80F;" FontSize="16"/>
            </Button>
            
            <!-- 刷新按鈕 -->
            <Button x:Name="RefreshButton"
                    Style="{StaticResource MaterialIconButtonStyle}"
                    Command="{Binding RefreshCommand}"
                    ToolTipService.ToolTip="重新整理">
                <FontIcon Glyph="&#xE72C;" FontSize="16"/>
            </Button>
        </StackPanel>

        <!-- 中間區域：標題（可拖曳移動視窗） -->
        <Grid Grid.Column="1" 
              x:Name="DraggableArea"
              Background="Transparent">
            <TextBlock x:Name="TitleText"
                       Text="{Binding Title, FallbackValue='Uno Platform App'}"
                       FontSize="14"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"/>
        </Grid>

        <!-- 右側區域：使用者資訊與視窗控制 -->
        <StackPanel Grid.Column="2" 
                    Orientation="Horizontal" 
                    Spacing="2"
                    VerticalAlignment="Center"
                    Margin="0,0,4,0">
            
            <!-- 搜尋按鈕 -->
            <Button x:Name="SearchButton"
                    Style="{StaticResource MaterialIconButtonStyle}"
                    Command="{Binding SearchCommand}"
                    ToolTipService.ToolTip="搜尋">
                <FontIcon Glyph="&#xE721;" FontSize="16"/>
            </Button>
            
            <!-- 通知按鈕 -->
            <Button x:Name="NotificationButton"
                    Style="{StaticResource MaterialIconButtonStyle}"
                    Command="{Binding NotificationCommand}"
                    ToolTipService.ToolTip="通知">
                <Grid>
                    <FontIcon Glyph="&#xE7E7;" FontSize="16"/>
                    <!-- 通知紅點 -->
                    <Ellipse Width="8" Height="8" 
                             Fill="Red" 
                             HorizontalAlignment="Right" 
                             VerticalAlignment="Top"
                             Margin="0,-2,-2,0"
                             Visibility="{Binding HasNotifications, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </Grid>
            </Button>
            
            <!-- 主題切換按鈕 -->
            <Button x:Name="ThemeToggleButton"
                    Style="{StaticResource MaterialIconButtonStyle}"
                    Command="{Binding ToggleThemeCommand}"
                    ToolTipService.ToolTip="切換主題">
                <FontIcon x:Name="ThemeIcon" 
                          Glyph="{Binding IsDarkTheme, Converter={StaticResource ThemeIconConverter}}" 
                          FontSize="16"/>
            </Button>
            
            <!-- 設定按鈕 -->
            <Button x:Name="SettingsButton"
                    Style="{StaticResource MaterialIconButtonStyle}"
                    Command="{Binding SettingsCommand}"
                    ToolTipService.ToolTip="設定">
                <FontIcon Glyph="&#xE713;" FontSize="16"/>
            </Button>
            
            <!-- 分隔線 -->
            <Border Width="1" 
                    Height="24" 
                    Background="{ThemeResource SystemControlForegroundBaseMediumLowBrush}"
                    Margin="4,0"/>
            
            <!-- 使用者頭像與資訊 -->
            <Button x:Name="UserButton"
                    Style="{StaticResource MaterialIconButtonStyle}"
                    Padding="4"
                    ToolTipService.ToolTip="{Binding UserName}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <PersonPicture DisplayName="{Binding UserName}"
                                   ProfilePicture="{Binding UserAvatar}"
                                   Width="28" 
                                   Height="28"/>
                    <TextBlock Text="{Binding UserName}" 
                               VerticalAlignment="Center"
                               FontSize="12"
                               Visibility="{Binding ShowUserName, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
                <Button.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="個人資料" Icon="Contact" Command="{Binding ProfileCommand}"/>
                        <MenuFlyoutItem Text="帳號設定" Icon="Setting" Command="{Binding AccountSettingsCommand}"/>
                        <MenuFlyoutSeparator/>
                        <MenuFlyoutItem Text="登出" Icon="BlockContact" Command="{Binding LogoutCommand}"/>
                    </MenuFlyout>
                </Button.Flyout>
            </Button>
            
            <!-- 視窗控制按鈕（僅 Desktop） -->
            <StackPanel x:Name="WindowControlButtons" 
                        Orientation="Horizontal" 
                        Spacing="0"
                        Margin="8,0,0,0">
                
                <!-- 最小化 -->
                <Button x:Name="MinimizeButton"
                        Style="{StaticResource WindowCaptionButtonStyle}"
                        Click="MinimizeButton_Click"
                        ToolTipService.ToolTip="最小化">
                    <FontIcon Glyph="&#xE921;" FontSize="10"/>
                </Button>
                
                <!-- 最大化/還原 -->
                <Button x:Name="MaximizeButton"
                        Style="{StaticResource WindowCaptionButtonStyle}"
                        Click="MaximizeButton_Click"
                        ToolTipService.ToolTip="最大化">
                    <FontIcon x:Name="MaximizeIcon" Glyph="&#xE922;" FontSize="10"/>
                </Button>
                
                <!-- 關閉 -->
                <Button x:Name="CloseButton"
                        Style="{StaticResource WindowCaptionCloseButtonStyle}"
                        Click="CloseButton_Click"
                        ToolTipService.ToolTip="關閉">
                    <FontIcon Glyph="&#xE8BB;" FontSize="10"/>
                </Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
