<Page x:Class="unoTest.Presentation.PluginUiTemplatePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource BackgroundBrush}">

    <Grid utu:SafeArea.Insets="VisibleBounds" Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="12"
                Padding="16"
                Margin="0,0,0,12">
            <StackPanel Spacing="6">
                <TextBlock x:Name="PageTitleText"
                           x:Uid="PluginUiTemplatePage.Title"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           Text="Plugin 動態模板頁"/>
                <TextBlock x:Name="PageDescriptionText"
                           x:Uid="PluginUiTemplatePage.Description"
                           Opacity="0.7"
                           TextWrapping="Wrap"
                           Text="此頁面會根據 JSON 文件動態產生控制項，並觸發 plugin action。"/>
                <TextBlock x:Name="StatusText"
                           x:Uid="PluginUiTemplatePage.Status"
                           Opacity="0.8"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0">
                <StackPanel x:Name="SectionsHost" Spacing="12"/>
            </ScrollViewer>

            <Border Grid.Column="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="12"
                    Padding="12">
                <StackPanel Spacing="8">
                    <TextBlock x:Uid="PluginUiTemplatePage.StateTitle"
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               Text="目前 State"/>
                    <TextBox x:Name="StatePreviewTextBox"
                             x:Uid="PluginUiTemplatePage.StatePreview"
                             AcceptsReturn="True"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             MinHeight="280"
                             VerticalAlignment="Stretch"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>