<Page x:Class="unoTest.Presentation.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:unoTest.Presentation"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:um="using:Uno.Material"
      xmlns:converters="using:unoTest.Converters"
      Background="{ThemeResource BackgroundBrush}">

    <!-- ====================================================================
         登入頁面模板
         
         功能說明：
         1. 使用者名稱/Email 輸入
         2. 密碼輸入（顯示/隱藏切換）
         3. 記住我功能
         4. 忘記密碼連結
         5. 第三方登入（Google, Microsoft, Apple）
         6. 註冊連結
         7. 表單驗證
         8. 載入中狀態
         ==================================================================== -->

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
    </Page.Resources>

    <Grid utu:SafeArea.Insets="VisibleBounds">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 背景漸層 -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{ThemeResource SystemAccentColor}" Offset="0"/>
                <GradientStop Color="{ThemeResource SystemAccentColorLight2}" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- 中央登入卡片 -->
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MinWidth="380"
                MaxWidth="440"
                Margin="24"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="16"
                Padding="40,48">

            <StackPanel Spacing="24">

                <!-- Logo 與標題區 -->
                <StackPanel HorizontalAlignment="Center" Spacing="16">
                    <!-- 應用 Logo -->
                    <Image Source="ms-appx:///Assets/Icons/icon_foreground.svg"
                           Width="80"
                           Height="80"
                           HorizontalAlignment="Center"/>

                    <!-- 歡迎文字 -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="歡迎回來"
                                   Style="{StaticResource TitleTextBlockStyle}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="登入您的帳號以繼續"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Opacity="0.7"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- 錯誤訊息 -->
                <InfoBar x:Name="ErrorInfoBar"
                         IsOpen="{Binding HasError}"
                         Severity="Error"
                         Title="登入失敗"
                         Message="{Binding ErrorMessage}"
                         IsClosable="True"/>

                <!-- 登入表單 -->
                <StackPanel Spacing="16">

                    <!-- 使用者名稱/Email -->
                    <TextBox x:Name="UsernameTextBox"
                             Header="使用者名稱或 Email"
                             PlaceholderText="請輸入使用者名稱或 Email"
                             Text="{Binding Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             InputScope="EmailNameOrAddress"
                             AutomationProperties.AutomationId="UsernameInput">
                        <TextBox.KeyboardAccelerators>
                            <KeyboardAccelerator Key="Enter" Invoked="OnEnterKeyInvoked"/>
                        </TextBox.KeyboardAccelerators>
                    </TextBox>

                    <!-- 密碼輸入 -->
                    <PasswordBox x:Name="PasswordBox"
                                 Header="密碼"
                                 PlaceholderText="請輸入密碼"
                                 Password="{Binding Password, Mode=TwoWay}"
                                 PasswordRevealMode="Peek"
                                 AutomationProperties.AutomationId="PasswordInput">
                        <PasswordBox.KeyboardAccelerators>
                            <KeyboardAccelerator Key="Enter" Invoked="OnLoginEnterKeyInvoked"/>
                        </PasswordBox.KeyboardAccelerators>
                    </PasswordBox>

                    <!-- 記住我 & 忘記密碼 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- 記住我 -->
                        <CheckBox Grid.Column="0"
                                  Content="記住我"
                                  IsChecked="{Binding RememberMe, Mode=TwoWay}"/>

                        <!-- 忘記密碼 -->
                        <HyperlinkButton Grid.Column="1"
                                         Content="忘記密碼？"
                                         Command="{Binding ForgotPasswordCommand}"
                                         Padding="0"/>
                    </Grid>

                    <!-- 登入按鈕 -->
                    <Button x:Name="LoginButton"
                            Content="登入"
                            Style="{StaticResource MaterialFilledButtonStyle}"
                            HorizontalAlignment="Stretch"
                            Height="44"
                            Command="{Binding LoginCommand}"
                            IsEnabled="{Binding CanLogin}"
                            AutomationProperties.AutomationId="LoginButton">
                        <!-- 載入中狀態 -->
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <Grid>
                                    <TextBlock Text="登入"
                                               Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                                    <StackPanel Orientation="Horizontal" 
                                                Spacing="8"
                                                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ProgressRing IsActive="True" Width="20" Height="20"/>
                                        <TextBlock Text="登入中..."/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                </StackPanel>

                <!-- 分隔線 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" 
                            Height="1" 
                            Background="{ThemeResource SystemControlForegroundBaseMediumLowBrush}"
                            VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" 
                               Text="或" 
                               Margin="16,0" 
                               Opacity="0.5"/>
                    <Border Grid.Column="2" 
                            Height="1" 
                            Background="{ThemeResource SystemControlForegroundBaseMediumLowBrush}"
                            VerticalAlignment="Center"/>
                </Grid>

                <!-- 第三方登入 -->
                <StackPanel Spacing="12">
                    <!-- Google 登入 -->
                    <Button HorizontalAlignment="Stretch"
                            Height="44"
                            Command="{Binding GoogleLoginCommand}"
                            Style="{StaticResource MaterialOutlinedButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE909;" FontSize="20"/>
                            <TextBlock Text="使用 Google 帳號登入" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Microsoft 登入 -->
                    <Button HorizontalAlignment="Stretch"
                            Height="44"
                            Command="{Binding MicrosoftLoginCommand}"
                            Style="{StaticResource MaterialOutlinedButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE782;" FontSize="20"/>
                            <TextBlock Text="使用 Microsoft 帳號登入" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Apple 登入（iOS 特有） -->
                    <Button HorizontalAlignment="Stretch"
                            Height="44"
                            Command="{Binding AppleLoginCommand}"
                            Style="{StaticResource MaterialOutlinedButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xF8A6;" FontSize="20"/>
                            <TextBlock Text="使用 Apple 帳號登入" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- 註冊連結 -->
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Center"
                            Spacing="4">
                    <TextBlock Text="還沒有帳號？" 
                               VerticalAlignment="Center"
                               Opacity="0.7"/>
                    <HyperlinkButton Content="立即註冊"
                                     Command="{Binding RegisterCommand}"
                                     Padding="0"/>
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- 載入中遮罩 -->
        <Grid Background="#80000000"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" 
                        VerticalAlignment="Center"
                        Spacing="16">
                <ProgressRing IsActive="True" Width="60" Height="60"/>
                <TextBlock Text="正在驗證..." 
                           Foreground="White"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
