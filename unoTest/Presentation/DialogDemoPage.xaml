<Page x:Class="unoTest.Presentation.DialogDemoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:unoTest.Presentation"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
      Background="{ThemeResource BackgroundBrush}">

    <!-- ====================================================================
         彈出視窗示範頁面
         展示各種 Dialog、Flyout、InfoBar 的使用方式
         ==================================================================== -->

    <Grid utu:SafeArea.Insets="VisibleBounds">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 標題列 -->
        <utu:NavigationBar Content="彈出視窗示範" Grid.Row="0"/>

        <!-- 通知列 -->
        <muxc:InfoBar x:Name="NotificationBar"
                      Grid.Row="1"
                      IsOpen="False"
                      Severity="Informational"/>

        <ScrollViewer Grid.Row="2" Padding="16">
            <StackPanel Spacing="24" MaxWidth="800" HorizontalAlignment="Left">

                <!-- ==================== ContentDialog ==================== -->
                <StackPanel Spacing="8">
                    <TextBlock Text="ContentDialog 對話框" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock Text="模態對話框，需要使用者回應後才能繼續" Opacity="0.7"/>
                    
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <Button Content="訊息對話框" Click="ShowMessage_Click"/>
                        <Button Content="確認對話框" Click="ShowConfirm_Click"/>
                        <Button Content="輸入對話框" Click="ShowInput_Click"/>
                        <Button Content="選擇對話框" Click="ShowSelection_Click"/>
                        <Button Content="自訂內容" Click="ShowCustom_Click"/>
                    </StackPanel>
                </StackPanel>

                <!-- ==================== Error Dialog ==================== -->
                <StackPanel Spacing="8">
                    <TextBlock Text="錯誤對話框" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock Text="顯示錯誤訊息、錯誤代碼和詳細堆疊追蹤" Opacity="0.7"/>
                    
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <Button Content="簡單錯誤" Click="ShowSimpleError_Click"/>
                        <Button Content="帶錯誤代碼" Click="ShowErrorWithCode_Click"/>
                        <Button Content="帶例外詳情" Click="ShowErrorWithException_Click"/>
                    </StackPanel>
                </StackPanel>

                <!-- ==================== Loading Dialog ==================== -->
                <StackPanel Spacing="8">
                    <TextBlock Text="載入中對話框" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock Text="顯示載入進度，阻止使用者互動" Opacity="0.7"/>
                    
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <Button Content="顯示載入中 (3秒)" Click="ShowLoading_Click"/>
                        <Button Content="顯示進度條" Click="ShowProgress_Click"/>
                    </StackPanel>
                </StackPanel>

                <!-- ==================== Flyout ==================== -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Flyout 彈出框" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock Text="輕量級彈出，點擊外部自動關閉" Opacity="0.7"/>
                    
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <Button Content="基本 Flyout">
                            <Button.Flyout>
                                <Flyout>
                                    <StackPanel Spacing="8" Width="200">
                                        <TextBlock Text="這是一個 Flyout" Style="{StaticResource SubtitleTextBlockStyle}"/>
                                        <TextBlock Text="點擊外部區域可關閉" TextWrapping="Wrap"/>
                                        <Button Content="關閉" Click="CloseFlyout_Click"/>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                        
                        <Button Content="選單 Flyout">
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="新增" Icon="Add"/>
                                    <MenuFlyoutItem Text="編輯" Icon="Edit"/>
                                    <MenuFlyoutSeparator/>
                                    <MenuFlyoutSubItem Text="更多選項">
                                        <MenuFlyoutItem Text="選項 1"/>
                                        <MenuFlyoutItem Text="選項 2"/>
                                        <MenuFlyoutItem Text="選項 3"/>
                                    </MenuFlyoutSubItem>
                                    <MenuFlyoutSeparator/>
                                    <MenuFlyoutItem Text="刪除" Icon="Delete"/>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>

                        <Button Content="日期選擇">
                            <Button.Flyout>
                                <DatePickerFlyout DatePicked="DatePicker_DatePicked"/>
                            </Button.Flyout>
                        </Button>

                        <Button Content="時間選擇">
                            <Button.Flyout>
                                <TimePickerFlyout TimePicked="TimePicker_TimePicked"/>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <!-- ==================== TeachingTip ==================== -->
                <StackPanel Spacing="8">
                    <TextBlock Text="TeachingTip 教學提示" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock Text="用於功能引導和提示" Opacity="0.7"/>
                    
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <Button x:Name="FeatureButton" Content="新功能按鈕" Click="ShowTeachingTip_Click"/>
                    </StackPanel>

                    <muxc:TeachingTip x:Name="FeatureTip"
                                      Target="{x:Bind FeatureButton}"
                                      Title="新功能介紹"
                                      Subtitle="這是一個新功能，點擊可以..."
                                      PreferredPlacement="Bottom"
                                      IsLightDismissEnabled="True"
                                      CloseButtonContent="知道了">
                        <muxc:TeachingTip.IconSource>
                            <muxc:SymbolIconSource Symbol="NewWindow"/>
                        </muxc:TeachingTip.IconSource>
                    </muxc:TeachingTip>
                </StackPanel>

                <!-- ==================== InfoBar ==================== -->
                <StackPanel Spacing="8">
                    <TextBlock Text="InfoBar 通知列" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock Text="非模態通知，不阻礙使用者操作" Opacity="0.7"/>
                    
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <Button Content="成功" Click="ShowSuccessInfo_Click"/>
                        <Button Content="警告" Click="ShowWarningInfo_Click"/>
                        <Button Content="錯誤" Click="ShowErrorInfo_Click"/>
                        <Button Content="資訊" Click="ShowInfo_Click"/>
                    </StackPanel>

                    <!-- 範例 InfoBar -->
                    <muxc:InfoBar x:Name="DemoInfoBar"
                                  Title="這是標題"
                                  Message="這是訊息內容"
                                  Severity="Informational"
                                  IsOpen="False"
                                  IsClosable="True"
                                  Margin="0,8,0,0"/>
                </StackPanel>

                <!-- ==================== ToolTip ==================== -->
                <StackPanel Spacing="8">
                    <TextBlock Text="ToolTip 工具提示" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock Text="滑鼠懸停時顯示的提示文字" Opacity="0.7"/>
                    
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <Button Content="基本提示" ToolTipService.ToolTip="這是基本的 ToolTip"/>
                        
                        <Button Content="自訂提示">
                            <ToolTipService.ToolTip>
                                <ToolTip>
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="自訂 ToolTip" FontWeight="Bold"/>
                                        <TextBlock Text="可以放入任何內容"/>
                                        <Image Source="ms-appx:///Assets/Icons/icon.png" Width="32" Height="32"/>
                                    </StackPanel>
                                </ToolTip>
                            </ToolTipService.ToolTip>
                        </Button>
                    </StackPanel>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
