<Page x:Class="unoTest.Presentation.CrudDemoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:unoTest.Presentation"
      xmlns:controls="using:unoTest.Controls"
      xmlns:converters="using:unoTest.Converters"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:um="using:Uno.Material"
      Background="{ThemeResource BackgroundBrush}">

    <!-- ====================================================================
         CRUD 增刪改查示範頁面
         
         功能說明：
         1. 產品列表顯示
         2. 搜尋與篩選
         3. 新增產品
         4. 編輯產品
         5. 刪除產品（單筆/批次）
         6. 分頁功能
         ==================================================================== -->

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <converters:NumberFormatConverter x:Key="NumberFormatConverter"/>
        <converters:DateFormatConverter x:Key="DateFormatConverter"/>
        <converters:StatusColorConverter x:Key="StatusColorConverter"/>
        <converters:StatusTextConverter x:Key="StatusTextConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 標題列 -->
        <utu:NavigationBar Content="產品管理（CRUD 示範）" Grid.Row="0"/>

        <!-- 主要內容 -->
        <Grid Grid.Row="1" Padding="16">
            <Grid.RowDefinitions>
                <!-- 工具列 -->
                <RowDefinition Height="Auto"/>
                <!-- 資料表格 -->
                <RowDefinition Height="*"/>
                <!-- 分頁控制 -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 工具列 -->
            <Border Grid.Row="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 搜尋與篩選 -->
                    <StackPanel Grid.Column="0" 
                                Orientation="Horizontal" 
                                Spacing="12">
                        <!-- 搜尋框 -->
                        <TextBox x:Name="SearchBox"
                                 PlaceholderText="搜尋產品名稱..."
                                 Width="250"
                                 Text="{Binding SearchKeyword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.KeyboardAccelerators>
                                <KeyboardAccelerator Key="Enter" Invoked="OnSearchEnterKeyInvoked"/>
                            </TextBox.KeyboardAccelerators>
                        </TextBox>

                        <!-- 分類篩選 -->
                        <ComboBox x:Name="CategoryComboBox"
                                  PlaceholderText="選擇分類"
                                  Width="150"
                                  ItemsSource="{Binding Categories}"
                                  SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                                  SelectionChanged="CategoryComboBox_SelectionChanged"/>

                        <!-- 搜尋按鈕 -->
                        <Button Content="搜尋"
                                Command="{Binding SearchCommand}"
                                Style="{StaticResource MaterialFilledButtonStyle}"/>

                        <!-- 清除篩選 -->
                        <Button Content="清除"
                                Command="{Binding ClearFilterCommand}"
                                Style="{StaticResource MaterialOutlinedButtonStyle}"/>
                    </StackPanel>

                    <!-- 操作按鈕 -->
                    <StackPanel Grid.Column="1" 
                                Orientation="Horizontal" 
                                Spacing="8">
                        <!-- 新增 -->
                        <Button Command="{Binding AddCommand}"
                                Style="{StaticResource MaterialFilledButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE710;" FontSize="16"/>
                                <TextBlock Text="新增"/>
                            </StackPanel>
                        </Button>

                        <!-- 批次刪除 -->
                        <Button Command="{Binding DeleteSelectedCommand}"
                                IsEnabled="{Binding HasSelection}"
                                Style="{StaticResource MaterialOutlinedButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE74D;" FontSize="16"/>
                                <TextBlock Text="刪除選中"/>
                            </StackPanel>
                        </Button>

                        <!-- 匯出 -->
                        <Button Command="{Binding ExportCommand}"
                                Style="{StaticResource MaterialTextButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xEDE1;" FontSize="16"/>
                                <TextBlock Text="匯出"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 資料表格 -->
            <Border Grid.Row="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="0">
                <Grid>
                    <!-- 載入中遮罩 -->
                    <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                          Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                          Canvas.ZIndex="100">
                        <StackPanel HorizontalAlignment="Center" 
                                    VerticalAlignment="Center"
                                    Spacing="12">
                            <ProgressRing IsActive="True" Width="40" Height="40"/>
                            <TextBlock Text="載入中..." Opacity="0.7"/>
                        </StackPanel>
                    </Grid>

                    <ListView x:Name="ProductListView"
                              ItemsSource="{Binding Products}"
                              SelectionMode="Multiple"
                              SelectionChanged="ProductListView_SelectionChanged">
                        
                        <!-- 表頭 -->
                        <ListView.Header>
                            <Grid Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}"
                                  Padding="16,12"
                                  BorderThickness="0,0,0,1"
                                  BorderBrush="{ThemeResource SystemControlForegroundBaseMediumLowBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="140"/>
                                </Grid.ColumnDefinitions>

                                <CheckBox Grid.Column="0" 
                                          IsChecked="{Binding IsAllSelected, Mode=TwoWay}"
                                          Click="SelectAllCheckBox_Click"/>
                                <TextBlock Grid.Column="1" Text="ID" FontWeight="Bold"/>
                                <TextBlock Grid.Column="2" Text="產品名稱" FontWeight="Bold"/>
                                <TextBlock Grid.Column="3" Text="分類" FontWeight="Bold"/>
                                <TextBlock Grid.Column="4" Text="價格" FontWeight="Bold" TextAlignment="Right"/>
                                <TextBlock Grid.Column="5" Text="庫存" FontWeight="Bold" TextAlignment="Right"/>
                                <TextBlock Grid.Column="6" Text="狀態" FontWeight="Bold" TextAlignment="Center"/>
                                <TextBlock Grid.Column="7" Text="操作" FontWeight="Bold" TextAlignment="Center"/>
                            </Grid>
                        </ListView.Header>

                        <!-- 資料行模板 -->
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="16,12"
                                      BorderThickness="0,0,0,1"
                                      BorderBrush="{ThemeResource SystemControlForegroundBaseMediumLowBrush}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="140"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 選擇框 -->
                                    <CheckBox Grid.Column="0" 
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"/>
                                    
                                    <!-- ID -->
                                    <TextBlock Grid.Column="1" 
                                               Text="{Binding Id}" 
                                               VerticalAlignment="Center"/>
                                    
                                    <!-- 產品名稱 -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" 
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Description}" 
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Opacity="0.6"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    
                                    <!-- 分類 -->
                                    <TextBlock Grid.Column="3" 
                                               Text="{Binding Category}" 
                                               VerticalAlignment="Center"/>
                                    
                                    <!-- 價格 -->
                                    <TextBlock Grid.Column="4" 
                                               Text="{Binding Price, Converter={StaticResource NumberFormatConverter}, ConverterParameter=N2}" 
                                               VerticalAlignment="Center"
                                               TextAlignment="Right"/>
                                    
                                    <!-- 庫存 -->
                                    <TextBlock Grid.Column="5" 
                                               Text="{Binding Stock}" 
                                               VerticalAlignment="Center"
                                               TextAlignment="Right"/>
                                    
                                    <!-- 狀態 -->
                                    <Border Grid.Column="6" 
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            CornerRadius="4"
                                            Padding="8,4">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding IsActive, Converter={StaticResource StatusColorConverter}}"/>
                                        </Border.Background>
                                        <TextBlock Text="{Binding IsActive, Converter={StaticResource StatusTextConverter}}"
                                                   FontSize="12"/>
                                    </Border>
                                    
                                    <!-- 操作按鈕 -->
                                    <StackPanel Grid.Column="7" 
                                                Orientation="Horizontal" 
                                                HorizontalAlignment="Center"
                                                Spacing="4">
                                        <Button ToolTipService.ToolTip="編輯"
                                                Style="{StaticResource MaterialIconButtonStyle}"
                                                Command="{Binding DataContext.EditCommand, ElementName=ProductListView}"
                                                CommandParameter="{Binding}">
                                            <FontIcon Glyph="&#xE70F;" FontSize="14"/>
                                        </Button>
                                        <Button ToolTipService.ToolTip="刪除"
                                                Style="{StaticResource MaterialIconButtonStyle}"
                                                Command="{Binding DataContext.DeleteCommand, ElementName=ProductListView}"
                                                CommandParameter="{Binding}">
                                            <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>

                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>

                    <!-- 空資料提示 -->
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibilityConverter}}">
                        <FontIcon Glyph="&#xE7BA;" FontSize="64" Opacity="0.3"/>
                        <TextBlock Text="沒有找到產品" 
                                   Style="{StaticResource SubtitleTextBlockStyle}"
                                   Opacity="0.5"
                                   Margin="0,16,0,0"/>
                        <Button Content="新增第一個產品"
                                Command="{Binding AddCommand}"
                                Style="{StaticResource MaterialTextButtonStyle}"
                                Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 分頁控制 -->
            <Border Grid.Row="2"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,16,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 顯示數量 -->
                    <StackPanel Grid.Column="0" 
                                Orientation="Horizontal" 
                                Spacing="8"
                                VerticalAlignment="Center">
                        <TextBlock Text="每頁顯示:" VerticalAlignment="Center"/>
                        <ComboBox x:Name="PageSizeComboBox"
                                  SelectedIndex="0"
                                  SelectionChanged="PageSizeComboBox_SelectionChanged">
                            <ComboBoxItem Content="10"/>
                            <ComboBoxItem Content="25"/>
                            <ComboBoxItem Content="50"/>
                            <ComboBoxItem Content="100"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- 頁面資訊 -->
                    <TextBlock Grid.Column="1"
                               Text="{Binding PageInfo}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Opacity="0.7"/>

                    <!-- 分頁按鈕 -->
                    <StackPanel Grid.Column="2" 
                                Orientation="Horizontal" 
                                Spacing="4">
                        <Button Content="⏮" 
                                Command="{Binding FirstPageCommand}"
                                IsEnabled="{Binding CanGoPrevious}"/>
                        <Button Content="◀" 
                                Command="{Binding PreviousPageCommand}"
                                IsEnabled="{Binding CanGoPrevious}"/>
                        <TextBlock Text="{Binding PageDisplay}" 
                                   VerticalAlignment="Center"
                                   Margin="8,0"/>
                        <Button Content="▶" 
                                Command="{Binding NextPageCommand}"
                                IsEnabled="{Binding CanGoNext}"/>
                        <Button Content="⏭" 
                                Command="{Binding LastPageCommand}"
                                IsEnabled="{Binding CanGoNext}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- 編輯對話框（以 Flyout 或 ContentDialog 方式呈現） -->
    </Grid>
</Page>
