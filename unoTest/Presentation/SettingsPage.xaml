<Page x:Class="unoTest.Presentation.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:unoTest.Presentation"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:converters="using:unoTest.Converters"
      Background="{ThemeResource BackgroundBrush}">

    <!-- ====================================================================
         設定頁面
         
         功能說明：
         1. 主題設定（深色/淺色/跟隨系統）
         2. 語言設定
         3. 通知設定
         4. 關於應用程式
         ==================================================================== -->

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <Grid utu:SafeArea.Insets="VisibleBounds">
        <ScrollViewer Padding="16">
            <StackPanel Spacing="16" MaxWidth="800">

                <!-- 外觀設定 -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Text="外觀" Style="{StaticResource SubtitleTextBlockStyle}"/>

                        <!-- 主題選擇 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="佈景主題"/>
                                <TextBlock Text="選擇應用程式的外觀主題" 
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Opacity="0.7"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1"
                                      Width="180"
                                      SelectedIndex="{Binding SelectedThemeIndex, Mode=TwoWay}">
                                <ComboBoxItem Content="跟隨系統"/>
                                <ComboBoxItem Content="淺色"/>
                                <ComboBoxItem Content="深色"/>
                            </ComboBox>
                        </Grid>

                        <Border Height="1" 
                                Background="{ThemeResource SystemControlForegroundBaseMediumLowBrush}"/>

                        <!-- 文字大小 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="文字大小"/>
                                <TextBlock Text="調整應用程式的文字顯示大小" 
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Opacity="0.7"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1"
                                      Width="180"
                                      SelectedIndex="{Binding SelectedFontSizeIndex, Mode=TwoWay}">
                                <ComboBoxItem Content="小"/>
                                <ComboBoxItem Content="標準"/>
                                <ComboBoxItem Content="大"/>
                                <ComboBoxItem Content="特大"/>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 語言設定 -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Text="語言與地區" Style="{StaticResource SubtitleTextBlockStyle}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="語言"/>
                                <TextBlock Text="選擇應用程式的顯示語言" 
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Opacity="0.7"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1"
                                      Width="180"
                                      ItemsSource="{Binding AvailableLanguages}"
                                      SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 通知設定 -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Text="通知" Style="{StaticResource SubtitleTextBlockStyle}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="啟用通知"/>
                                <TextBlock Text="接收應用程式通知" 
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Opacity="0.7"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                          IsOn="{Binding IsNotificationsEnabled, Mode=TwoWay}"
                                          OnContent=""
                                          OffContent=""/>
                        </Grid>

                        <Border Height="1" 
                                Background="{ThemeResource SystemControlForegroundBaseMediumLowBrush}"/>

                        <Grid Opacity="{Binding IsNotificationsEnabled, Converter={StaticResource EnabledOpacityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="音效"/>
                                <TextBlock Text="收到通知時播放音效" 
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Opacity="0.7"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                          IsOn="{Binding IsSoundEnabled, Mode=TwoWay}"
                                          IsEnabled="{Binding IsNotificationsEnabled}"
                                          OnContent=""
                                          OffContent=""/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 資料與隱私 -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Text="資料與隱私" Style="{StaticResource SubtitleTextBlockStyle}"/>

                        <Button Content="清除快取"
                                Command="{Binding ClearCacheCommand}"
                                HorizontalAlignment="Stretch"/>

                        <Button Content="匯出我的資料"
                                Command="{Binding ExportDataCommand}"
                                HorizontalAlignment="Stretch"/>

                        <Button Content="刪除帳號"
                                Style="{StaticResource MaterialOutlinedButtonStyle}"
                                Foreground="Red"
                                Command="{Binding DeleteAccountCommand}"
                                HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>

                <!-- 關於 -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Text="關於" Style="{StaticResource SubtitleTextBlockStyle}"/>

                        <StackPanel Spacing="8">
                            <TextBlock Text="{Binding AppName}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding AppVersion}" Opacity="0.7"/>
                        </StackPanel>

                        <Border Height="1" 
                                Background="{ThemeResource SystemControlForegroundBaseMediumLowBrush}"/>

                        <HyperlinkButton Content="隱私權政策" 
                                         NavigateUri="https://example.com/privacy"/>
                        <HyperlinkButton Content="使用條款" 
                                         NavigateUri="https://example.com/terms"/>
                        <HyperlinkButton Content="開源授權" 
                                         Command="{Binding ShowLicensesCommand}"/>

                        <Border Height="1" 
                                Background="{ThemeResource SystemControlForegroundBaseMediumLowBrush}"/>

                        <Button Content="檢查更新"
                                Command="{Binding CheckUpdateCommand}"
                                HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
