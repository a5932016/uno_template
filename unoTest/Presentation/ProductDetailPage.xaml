<Page x:Class="unoTest.Presentation.ProductDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:unoTest.Presentation"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource BackgroundBrush}">

  <!--
    產品詳情頁面
    示範：接收從列表頁傳來的 ProductNavData（包含 ID）並顯示

    進入此頁面時，ProductDetailViewModel 會呼叫 TitleBarStateService.SetDetailMode(...)
    TitleBar 的中間欄會從「Tab 列」切換為「頁面標題 + 返回按鈕」，展示不同樣式
  -->

  <ScrollViewer>
    <Grid utu:SafeArea.Insets="VisibleBounds"
          Padding="16"
          MaxWidth="700"
          HorizontalAlignment="Center">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- ============================================================
           說明卡：示範導航資料傳遞原理
           ============================================================ -->
      <Border Grid.Row="0"
              Background="{ThemeResource SystemAccentColorLight3}"
              CornerRadius="10"
              Padding="16"
              Margin="0,0,0,16">
        <StackPanel Spacing="4">
          <TextBlock Text="📋 資料傳遞示範說明"
                     FontWeight="SemiBold"/>
          <TextBlock TextWrapping="Wrap"
                     Opacity="0.8"
                     FontSize="13">
            上一頁（ProductListPage）點擊「查看詳情」時，將 ProductNavData 透過
            NavigateViewModelAsync&lt;ProductDetailViewModel&gt;(data: navData) 傳入。
            Uno Extensions 自動把 navData 注入到本 ViewModel 的建構子，
            不需要任何全域狀態或靜態變數。
          </TextBlock>
          <TextBlock TextWrapping="Wrap"
                     Opacity="0.8"
                     FontSize="13"
                     Margin="0,4,0,0">
            同時，本 ViewModel 呼叫 TitleBarStateService.SetDetailMode(...)，
            讓 TitleBar 切換為「返回按鈕 + 標題」樣式（Detail 模式）。
          </TextBlock>
        </StackPanel>
      </Border>

      <!-- ============================================================
           產品詳情卡
           ============================================================ -->
      <Border Grid.Row="1"
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              CornerRadius="12"
              Padding="24"
              Margin="0,0,0,16">
        <StackPanel Spacing="16">

          <!-- Header：ID 徽章 + 產品名稱 -->
          <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
            <Border Background="{ThemeResource SystemAccentColor}"
                    CornerRadius="10"
                    Padding="12,8">
              <TextBlock Text="{Binding IdBadgeText}"
                         FontWeight="Bold"
                         FontSize="18"
                         Foreground="White"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
              <TextBlock Text="{Binding Name}"
                         Style="{StaticResource TitleTextBlockStyle}"/>
              <TextBlock Text="{Binding Category}"
                         Style="{StaticResource SubtitleTextBlockStyle}"
                         Opacity="0.6"/>
            </StackPanel>
          </StackPanel>

          <!-- 分隔線 -->
          <Border Height="1"
                  Background="{ThemeResource SystemControlForegroundBaseMediumLowBrush}"/>

          <!-- 詳細資訊 Grid -->
          <Grid RowSpacing="12" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="120"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition/>
              <RowDefinition/>
              <RowDefinition/>
              <RowDefinition/>
            </Grid.RowDefinitions>

            <!-- 產品 ID -->
            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="產品 ID"
                       Opacity="0.6"
                       VerticalAlignment="Center"/>
            <TextBlock Grid.Row="0" Grid.Column="1"
                       Text="{Binding Id}"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>

            <!-- 分類 -->
            <TextBlock Grid.Row="1" Grid.Column="0"
                       Text="分類"
                       Opacity="0.6"
                       VerticalAlignment="Center"/>
            <TextBlock Grid.Row="1" Grid.Column="1"
                       Text="{Binding Category}"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>

            <!-- 價格 -->
            <TextBlock Grid.Row="2" Grid.Column="0"
                       Text="定價"
                       Opacity="0.6"
                       VerticalAlignment="Center"/>
            <TextBlock Grid.Row="2" Grid.Column="1"
                       Text="{Binding PriceText}"
                       FontWeight="Bold"
                       FontSize="20"
                       Foreground="{ThemeResource SystemAccentColor}"
                       VerticalAlignment="Center"/>

            <!-- 狀態 -->
            <TextBlock Grid.Row="3" Grid.Column="0"
                       Text="狀態"
                       Opacity="0.6"
                       VerticalAlignment="Center"/>
            <Border Grid.Row="3" Grid.Column="1"
                    CornerRadius="5"
                    Padding="10,4"
                    HorizontalAlignment="Left">
              <Border.Background>
                <SolidColorBrush Color="{ThemeResource SystemAccentColorLight2}"/>
              </Border.Background>
              <TextBlock Text="{Binding StatusText}"
                         FontWeight="SemiBold"
                         FontSize="13"/>
            </Border>
          </Grid>
        </StackPanel>
      </Border>

      <!-- ============================================================
           TitleBar 模式說明卡
           ============================================================ -->
      <Border Grid.Row="2"
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              CornerRadius="10"
              Padding="16">
        <StackPanel Spacing="8">
          <TextBlock Text="🔷 TitleBar 樣式切換原理"
                     FontWeight="SemiBold"/>
          <TextBlock TextWrapping="Wrap" Opacity="0.8" FontSize="13">
            <Run Text="進入此頁面 → "/>
            <Run Text="ProductDetailViewModel 建構子呼叫 TitleBarStateService.SetDetailMode()" FontWeight="SemiBold"/>
            <Run Text=" → TitleBarViewModel 監聽到狀態改變 → CustomTitleBar.xaml.cs 呼叫 VisualStateManager.GoToState(this, &quot;DetailMode&quot;) → Tab 列隱藏，返回按鈕 + 標題出現"/>
          </TextBlock>
          <TextBlock TextWrapping="Wrap" Opacity="0.8" FontSize="13">
            返回時 → TitleBarViewModel.BackCommand → GoBackAsync() → TitleBarStateService.SetTabsMode() → 恢復 Tabs 模式
          </TextBlock>
        </StackPanel>
      </Border>

    </Grid>
  </ScrollViewer>
</Page>
